# --- Build output (Zephyr / west / CMake) ---
# west build dirs are large and contain generated TF-M signing keys + binaries.
build/
build_*/
twister-out*/

# Compiled / binary artifacts
*.o
*.obj
*.a
*.elf
*.bin
*.hex
*.map
*.lst

# --- Secrets: per-device TLS credentials ---
# device_credentials.h is GENERATED and contains the device PRIVATE KEY -- NEVER
# commit it. quickstart_credentials.h (public CA roots only) is safe and committed.
device_credentials.h

# Key material of any kind (safety net)
*.pem
*.key
*.der
*.p12
*.pfx

# --- eIQ Time Series Studio deployment package -------------------------------
# The pretrained model in demos/eiq-pdm-vibration/model/ IS committed (NXP
# LA_OPT Online Code Hosting license; LICENSE.txt ships alongside) -- un-ignore
# its .a from the global binary-artifact rule above.
!demos/eiq-pdm-vibration/model/libtss.a

# --- Editor / OS ---
.DS_Store
Thumbs.db
*.swp
*~
