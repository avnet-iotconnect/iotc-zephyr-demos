/*
 * FRDM-MCXN947: enable the mikroBUS / Shuttle I2C bus (flexcomm3_lpi2c3) for the
 * MIKROE Ultra-Low Press (SDP810) Click. No Ethernet needed -- capture is
 * network-free. The SDP810 is read via raw I2C in the app, so no sensor DT node
 * is required.
 */

&mikrobus_i2c {
	status = "okay";
	clock-frequency = <100000>;
};
