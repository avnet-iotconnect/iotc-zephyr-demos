/*
 * Phase 2 (connect mode) only: enable the FRDM-MCXN947 Ethernet (ENET-QoS +
 * LAN8741) for the /IOTCONNECT uplink. Applied on top of the base board overlay
 * via -DEXTRA_DTC_OVERLAY_FILE=connect.overlay so the capture build stays
 * network-free.
 */

&enet {
	pinctrl-0 = <&pinmux_enet_qos>;
	pinctrl-names = "default";
	status = "okay";
};

&enet_mac {
	status = "okay";
	phy-connection-type = "rmii";
	zephyr,random-mac-address;
	phy-handle = <&phy>;
};

&enet_mdio {
	status = "okay";

	phy: ethernet-phy@0 {
		compatible = "ethernet-phy";
		reg = <0>;
		status = "okay";
	};
};
